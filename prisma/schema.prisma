generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Warga {
  id              Int      @id @default(autoincrement())
  nama            String
  tanggalLahir    String
  jenisKelamin    String?
  nik             String   @unique
  noKK            String
  alamat          String?
  statusKeluarga  String
  statusWarga     String   @default("Aktif")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PengaturanRt {
  id          Int      @id
  namaRT      String   @default("")
  namaRW      String   @default("")
  kelurahan   String   @default("")
  kecamatan   String   @default("")
  kota        String   @default("")
  provinsi    String   @default("")
  namaKetuaRT String   @default("")
  noHpKetuaRT String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LandingBanner {
  id          Int      @id
  isActive    Boolean  @default(false)
  eyebrow     String   @default("")
  title       String   @default("")
  description String   @default("")
  imageUrl    String   @default("")
  buttonText  String   @default("")
  buttonUrl   String   @default("")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model LandingContent {
  id                Int      @id
  heroBadge         String   @default("")
  heroTitle         String   @default("")
  heroDescription   String   @default("")
  heroImageUrl      String   @default("")
  aboutLabel        String   @default("")
  aboutTitle        String   @default("")
  aboutDescription1 String   @default("")
  aboutDescription2 String   @default("")
  areaImageUrl      String   @default("")
  ctaTitle          String   @default("")
  ctaDescription    String   @default("")
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}