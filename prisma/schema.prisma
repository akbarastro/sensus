generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Warga {
  id              Int      @id @default(autoincrement())
  nama            String
  tanggalLahir    String
  jenisKelamin    String?
  nik             String   @unique
  noKK            String
  alamat          String?
  statusKeluarga  String
  statusWarga     String   @default("Aktif")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PengaturanRt {
  id          Int      @id
  namaRT      String   @default("")
  namaRW      String   @default("")
  kelurahan   String   @default("")
  kecamatan   String   @default("")
  kota        String   @default("")
  provinsi    String   @default("")
  namaKetuaRT String   @default("")
  noHpKetuaRT String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}